# ------------------------------------------------------------
# General
# ------------------------------------------------------------
ENV=development
LOG_LEVEL=INFO
APP_TIMEZONE=Asia/Kolkata

# ------------------------------------------------------------
# API / Server
# ------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ------------------------------------------------------------
# Optional Next.js frontend / BFF
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
PYTHON_RAG_BASE_URL=http://localhost:8000

# ------------------------------------------------------------
# LLM Provider (Phase 5 - Groq implementation)
# Set your provider key; do NOT commit real secrets.
# ------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq
LLM_MODEL=llama3-70b-8192
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=512

# ------------------------------------------------------------
# Embeddings
# ------------------------------------------------------------
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
#EMBEDDING_API_KEY=your_embedding_api_key_here

# ------------------------------------------------------------
# Retrieval / Index
# ------------------------------------------------------------
# Local ChromaDB storage directory
VECTOR_STORE_BACKEND=chroma
VECTOR_STORE_PATH=./data/index/chroma
COLLECTION_NAME=mf_faq_chunks
RETRIEVAL_TOP_K=6
RETRIEVAL_MIN_SCORE=0.2
USE_HYBRID_RETRIEVAL=false
USE_MMR=true

# ------------------------------------------------------------
# Chunking
# ------------------------------------------------------------
CHUNK_SIZE=700
CHUNK_OVERLAP=100

# ------------------------------------------------------------
# Corpus / Source policy
# ------------------------------------------------------------
AMC_NAME=HDFC Mutual Fund
URL_REGISTRY_PATH=./config/url_registry.yaml
SOURCE_ALLOWLIST_PATH=./config/source_allowlist.txt
SOURCE_BLOCKLIST_PATH=./config/source_blocklist.txt

# ------------------------------------------------------------
# Session / Thread storage
# ------------------------------------------------------------
SESSION_BACKEND=sqlite
SESSION_DB_PATH=./data/sessions/threads.db
THREAD_HISTORY_WINDOW=8

# ------------------------------------------------------------
# Output guardrails (facts-only contract)
# ------------------------------------------------------------
MAX_RESPONSE_SENTENCES=3
EXACTLY_ONE_CITATION=true
ENABLE_REFUSAL_GUARD=true
REFUSAL_LINKS_PATH=./doc/templates/refusal_educational_links.yaml
ANSWER_FOOTER_TEMPLATE_PATH=./doc/templates/answer_footer.txt

# ------------------------------------------------------------
# Ingestion
# ------------------------------------------------------------
FETCH_TIMEOUT_SECONDS=30
FETCH_MAX_RETRIES=3
FETCH_USER_AGENT=MutualFundFAQAssistantBot/1.0
RAW_DATA_DIR=./data/raw
PROCESSED_TEXT_DIR=./data/processed/text
CHUNKS_OUTPUT_PATH=./data/chunks/chunks.jsonl

# ------------------------------------------------------------
# Security / Rate limiting
# ------------------------------------------------------------
ENABLE_RATE_LIMIT=true
RATE_LIMIT_PER_MINUTE=60
MAX_INPUT_CHARS=4000
