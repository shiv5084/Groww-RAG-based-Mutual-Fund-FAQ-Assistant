{
  "version": 2,
  "name": "groww-mf-ai-assistant",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "URL of the backend API",
      "value": "https://your-backend.onrender.com/api/v1"
    }
  }
}
